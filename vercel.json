{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/frontend/dist/assets/$1"
    },
    {
      "source": "/favicon.svg",
      "destination": "/frontend/dist/favicon.svg"
    },
    {
      "source": "/icons.svg",
      "destination": "/frontend/dist/icons.svg"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
